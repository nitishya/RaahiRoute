// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Trip {
  id          String   @id @default(uuid())
  destination String
  budget      Float
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime @default(now())
}
